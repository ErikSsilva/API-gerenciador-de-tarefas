{
  "compilerOptions": {

    "target": "ES2022",
    "lib": ["ES2023"],

    "rootDir": "./src",
    "outDir": "./dist",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["node"],

    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
   
    "strict": true,
    "skipLibCheck": true,
  },

  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "jest.config.ts",
    "*.config.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  
}
